# ============================================================================
# SentinelAI backend configuration
# Copy this file to `.env.local` and fill in the values. Never commit `.env.local`.
# ============================================================================

# --- Gemini (Google Gen AI) -------------------------------------------------
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional overrides (defaults shown):
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- GitHub -----------------------------------------------------------------
# A Personal Access Token (fine-grained or classic) with `repo` read access.
# Create at https://github.com/settings/tokens
# Optional for public repos, but avoids strict rate limits.
GITHUB_TOKEN=your-github-pat
# GITHUB_API_VERSION=2022-11-28
# COMMIT_SCAN_LIMIT=30

# --- Slack ------------------------------------------------------------------
# Global fallback Incoming Webhook. Per-project webhooks (sent per request)
# take precedence. Create at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- ChromaDB ---------------------------------------------------------------
# Where the on-disk vector store lives (mounted as a volume in Docker).
# CHROMA_PERSIST_DIR=./data/chroma
# RUNBOOKS_COLLECTION=runbooks

# --- CORS (production) ------------------------------------------------------
# Your Vercel frontend URL so the browser can call this API from production.
# Set this on Render (Environment), not only in this local file.
# FRONTEND_URL=https://your-app.vercel.app
